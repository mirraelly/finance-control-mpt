<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="007-create-cidade-estado-table" author="eduardo">

        <createTable tableName="estado">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="nome" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="sigla" type="CHAR(2)">
                <constraints nullable="false"/>
            </column>
            <column name="codigo_ibge" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="ativo" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="cidade">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="nome" type="VARCHAR(150)">
                <constraints nullable="false"/>
            </column>
            <column name="estado_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="codigo_ibge" type="INTEGER"/>
            <column name="ativo" type="BOOLEAN" defaultValueBoolean="true"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName       ="cidade"
                baseColumnNames     ="estado_id"
                referencedTableName ="estado"
                referencedColumnNames="id"
                constraintName      ="fk_cidade_estado"/>

        <createIndex tableName="cidade" indexName="idx_cidade_estado">
            <column name="estado_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>